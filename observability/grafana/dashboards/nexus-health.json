{
  "uid": "nexus-health",
  "title": "NexusCommerce — Service Health",
  "tags": ["nexuscommerce", "opsforge"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service up",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}", "refId": "A", "instant": true }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (rate(http_requests_received_total[1m]))", "legendFormat": "{{job}}", "refId": "A" },
        { "expr": "sum by (job) (rate(http_requests_total[1m]))", "legendFormat": "{{job}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 12 }, "unit": "reqps" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 12 }, "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "5xx error rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (rate(http_requests_received_total{code=~\"5..\"}[5m]))", "legendFormat": "{{job}} (.NET)", "refId": "A" },
        { "expr": "sum by (job) (rate(http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "{{job}} (py)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20 },
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Process resident memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 12 }, "unit": "bytes" } }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
